{
  "Database": {
    "Active": "SQL",
    "LiteDb": {
      "Path": "LocalDatabas/litedb.db"
    },
    "SQL": {
      "ConnectionStrings": {
        "SqlConnection": "Server=localhost,1433;Database=TiendaMusicaDB;User Id=sa;Password=Colombia2026*;Encrypt=False;TrustServerCertificate=True"
      }
    }
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "Exchange": "tienda.musica.events"
  },
  "CircuitBreaker": {
    "EventsAllowedBeforeBreaking": 3,
    "DurationOfBreakInSeconds": 3
  },
  "ApplicationInsights": {
    "ConnectionString": "InstrumentationKey=00000000-0000-0000-0000-000000000000"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.ApplicationInsights" ],
    "Enrich": [ "FromLogContext", "WithThreadId" ],
    "Properties": {
      "Application": "ms-instruments",
      "Environment": "Development"
    },
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "ApplicationInsights",
        "Args": {
          "telemetryConverter": "Serilog.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
        }
      }
    ]
  }
}
